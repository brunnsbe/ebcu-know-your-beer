---
layout: layouts/base.njk
---

{% set topicData = topics | findBySlug(slug) %}
{% set uiLang = page.lang or 'en' %}
{% set langPrefix = '' %}
{% if page.lang and page.lang != 'en' %}
  {% set langPrefix = '/' + page.lang %}
{% endif %}

{# Topic header with blue background #}
<div class="bg-ebcu-blue pt-24 pb-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <nav class="text-sm text-white/70 mb-4">
      <a href="{{ langPrefix }}/read-the-label/" class="hover:text-white">{{ ui[uiLang].breadcrumb_read }}</a>
      <span class="mx-2">/</span>
      <span class="text-white">{{ title }}</span>
    </nav>
    <h1 class="text-3xl sm:text-4xl font-bold text-white">{{ title }}</h1>
    {% if topicData.lead %}
    <p class="mt-4 text-lg text-white/90 max-w-2xl">{{ topicData.lead }}</p>
    {% endif %}
  </div>
</div>

<div class="mx-auto max-w-7xl px-4 sm:px-6 py-12">
  <article class="prose prose-lg max-w-none">
    {{ content | safe }}
  </article>

  {# All topics #}
  <footer class="border-t border-gray-200 pt-12 mt-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ ui[uiLang].all_topics }}</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {% for t in topics %}
        {% if t.slug == slug %}
        <div class="rounded-xl border-2 border-ebcu-blue bg-ebcu-blue-light p-5">
          <div class="w-10 h-10 rounded-lg bg-ebcu-blue/10 flex items-center justify-center text-ebcu-blue mb-3">
            {% if t.icon == "percent" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M17 17h.01M7 17L17 7"></path><circle cx="7" cy="7" r="2" stroke-width="2"></circle><circle cx="17" cy="17" r="2" stroke-width="2"></circle></svg>
            {% elif t.icon == "grain" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            {% elif t.icon == "users" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            {% elif t.icon == "badge" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
            {% elif t.icon == "calendar" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            {% elif t.icon == "storage" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            {% endif %}
          </div>
          <h3 class="font-semibold text-ebcu-blue">{{ t.title }}</h3>
          <p class="text-sm text-gray-600 mt-1">{{ t.lead }}</p>
        </div>
        {% else %}
        <a class="rounded-xl bg-ebcu-blue p-5 hover:bg-ebcu-blue-dark hover:shadow-md transition-all" href="{{ langPrefix }}/topics/{{ t.slug }}/">
          <div class="w-10 h-10 rounded-lg bg-white/20 flex items-center justify-center text-white mb-3">
            {% if t.icon == "percent" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M17 17h.01M7 17L17 7"></path><circle cx="7" cy="7" r="2" stroke-width="2"></circle><circle cx="17" cy="17" r="2" stroke-width="2"></circle></svg>
            {% elif t.icon == "grain" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            {% elif t.icon == "users" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            {% elif t.icon == "badge" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
            {% elif t.icon == "calendar" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            {% elif t.icon == "storage" %}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            {% endif %}
          </div>
          <h3 class="font-semibold text-white">{{ t.title }}</h3>
          <p class="text-sm text-white/90 mt-1">{{ t.lead }}</p>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </footer>
</div>
